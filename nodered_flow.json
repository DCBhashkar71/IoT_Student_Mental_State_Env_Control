    {
        "id": "mqtt_in_co2",
        "type": "mqtt in",
        "z": "tab_smartdesk",
        "name": "📡 CO2 Sensor",
        "topic": "/smartdesk/env/co2",
        "qos": "1",
        "datatype": "json",
        "broker": "mqtt_broker_local",
        "nl": false,
        "rap": false,
        "rh": 0,
        "x": 130,
        "y": 80,
        "wires": [["parse_co2"]]
    },
    {
        "id": "parse_co2",
        "type": "function",
        "z": "tab_smartdesk",
        "name": "Parse CO2",
        "func": "var payload = msg.payload;\nvar co2 = payload.value;\n\nmsg.payload = co2;\nmsg.topic = 'co2';\nflow.set('co2', co2);\n\n// Threshold check\nif (co2 > 1000) {\n    node.send([msg, {\n        payload: {\n            type: 'co2',\n            level: 'HIGH',\n            value: co2,\n            message: '⚠️ CO2 HIGH (' + co2 + ' ppm) — Activating Fans at 80% PWM',\n            action: 'FAN_HIGH'\n        },\n        topic: 'alert'\n    }]);\n} else {\n    node.send([msg, null]);\n}\nreturn null;",
        "outputs": 2,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 310,
        "y": 80,
        "wires": [["gauge_co2", "chart_co2"], ["alert_handler"]]
    },
    {
        "id": "gauge_co2",
        "type": "ui_gauge",
        "z": "tab_smartdesk",
        "name": "CO2 Gauge",
        "group": "ui_group_env",
        "order": 1,
        "width": "3",
        "height": "3",
        "gtype": "gage",
        "title": "CO₂ Level",
        "label": "ppm",
        "format": "{{value}}",
        "min": "300",
        "max": "2000",
        "colors": ["#00b050", "#ffbf00", "#e02020"],
        "seg1": "600",
        "seg2": "1000",
        "className": "",
        "x": 520,
        "y": 60,
        "wires": []
    },
    {
        "id": "chart_co2",
        "type": "ui_chart",
        "z": "tab_smartdesk",
        "name": "CO2 History",
        "group": "ui_group_env",
        "order": 2,
        "width": "6",
        "height": "4",
        "label": "CO₂ ppm (last 60 readings)",
        "chartType": "line",
        "legend": "false",
        "xformat": "HH:mm:ss",
        "interpolate": "linear",
        "nodata": "",
        "dot": false,
        "ymin": "300",
        "ymax": "2000",
        "removeOlder": "60",
        "removeOlderPoints": "60",
        "removeOlderUnit": "1",
