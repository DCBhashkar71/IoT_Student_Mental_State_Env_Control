    {
        "id": "alert_handler",
        "type": "function",
        "z": "tab_smartdesk",
        "name": "Alert Aggregator",
        "func": "var alert = msg.payload;\nvar log = flow.get('alertLog') || [];\nlog.unshift('[' + new Date().toLocaleTimeString() + '] ' + alert.message);\nif (log.length > 20) log = log.slice(0, 20);\nflow.set('alertLog', log);\nmsg.payload = log.join('\\n');\nreturn msg;",
