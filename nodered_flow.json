    {
        "id": "mqtt_in_state",
        "type": "mqtt in",
        "z": "tab_smartdesk",
        "name": "🧠 Student State",
        "topic": "/smartdesk/state/student",
        "qos": "1",
        "datatype": "json",
        "broker": "mqtt_broker_local",
        "x": 130,
        "y": 760,
        "wires": [["parse_state"]]
    },
    {
        "id": "parse_state",
        "type": "function",
        "z": "tab_smartdesk",
        "name": "Format State Display",
        "func": "var data = msg.payload;\nvar state = data.state;\nvar fatigue = Math.round(data.fatigue * 100);\nvar stress  = Math.round(data.stress * 100);\n\nvar stateColors = {\n    'FOCUSED':  '#00b050',\n    'NORMAL':   '#0070c0',\n    'FATIGUED': '#ffbf00',\n    'STRESSED': '#e02020',\n    'BREAK':    '#7f7f7f'\n};\nvar stateEmoji = {\n    'FOCUSED':  '🟢',\n    'NORMAL':   '🔵',\n    'FATIGUED': '🟡',\n    'STRESSED': '🔴',\n    'BREAK':    '⚪'\n};\n\nmsg.payload = (stateEmoji[state] || '⚫') + ' ' + state;\nmsg.style = { color: stateColors[state] || '#888888' };\n\nnode.send([msg, {\n    payload: fatigue,\n    topic: 'fatigue'\n}, {\n    payload: stress,\n    topic: 'stress'\n}]);\nreturn null;",
        "outputs": 3,
        "x": 330,
        "y": 760,
        "wires": [["display_state"], ["gauge_fatigue"], ["gauge_stress"]]
    },
