    {
        "id": "parse_hrv",
        "type": "function",
        "z": "tab_smartdesk",
        "name": "Parse HRV + Stress Logic",
        "func": "var hrv = msg.payload.value;\nvar hr  = flow.get('hr') || 70;\nmsg.payload = hrv;\nflow.set('hrv', hrv);\n\nif (hrv < 25 && hr > 90) {\n    node.send([msg, {\n        payload: {\n            type: 'stress',\n            level: 'HIGH',\n            value: hrv,\n            message: '😰 STRESS DETECTED — HRV=' + hrv + 'ms, HR=' + hr + 'bpm. Break recommended!',\n            action: 'SUGGEST_BREAK'\n        },\n        topic: 'alert'\n    }]);\n} else {\n    node.send([msg, null]);\n}\nreturn null;",
        "outputs": 2,
        "x": 320,
        "y": 440,
        "wires": [["gauge_hrv"], ["alert_handler"]]
    },
