    {
        "id": "mqtt_in_posture",
        "type": "mqtt in",
        "z": "tab_smartdesk",
        "name": "🧍 Posture Sensor",
        "topic": "/smartdesk/behavior/posture",
        "qos": "1",
        "datatype": "json",
        "broker": "mqtt_broker_local",
        "x": 130,
        "y": 640,
        "wires": [["parse_posture"]]
    },
    {
        "id": "parse_posture",
        "type": "function",
        "z": "tab_smartdesk",
        "name": "Parse Posture + HC-SR04 Logic",
        "func": "var dist = msg.payload.value;\nmsg.payload = dist;\nflow.set('posture', dist);\n\n// Bad posture: <35cm for sustained period\nvar badCount = flow.get('postureCount') || 0;\nif (dist < 35) {\n    badCount++;\n    flow.set('postureCount', badCount);\n} else {\n    flow.set('postureCount', 0);\n    badCount = 0;\n}\n\n// After 10 bad readings (=10 seconds, simulating 2-min in fast-sim)\nif (badCount >= 10) {\n    node.send([msg, {\n        payload: {\n            type: 'posture',\n            level: 'BAD',\n            value: dist,\n            message: '📐 POOR POSTURE — Distance=' + dist + 'cm (<35cm). Haptic vibration active!',\n            action: 'HAPTIC_ON'\n        },\n        topic: 'alert'\n    }]);\n} else {\n    node.send([msg, null]);\n}\nreturn null;",
        "outputs": 2,
        "x": 320,
        "y": 640,
        "wires": [["gauge_posture"], ["alert_handler"]]
    },
