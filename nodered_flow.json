    {
        "id": "mqtt_in_lux",
        "type": "mqtt in",
        "z": "tab_smartdesk",
        "name": "💡 Light Sensor",
        "topic": "/smartdesk/env/lux",
        "qos": "1",
        "datatype": "json",
        "broker": "mqtt_broker_local",
        "x": 130,
        "y": 160,
        "wires": [["parse_lux"]]
    },
    {
        "id": "parse_lux",
        "type": "function",
        "z": "tab_smartdesk",
        "name": "Parse Lux + LED Logic",
        "func": "var lux = msg.payload.value;\nmsg.payload = lux;\nflow.set('lux', lux);\n\nif (lux < 300) {\n    var brightness = Math.min(100, Math.round(70 + (500 - lux) / 5));\n    node.send([msg, {\n        payload: {\n            type: 'light',\n            level: 'LOW',\n            value: lux,\n            message: '💡 LOW LIGHT (' + lux + ' lux) — Boosting LED to ' + brightness + '%',\n            action: 'LED_BOOST',\n            brightness: brightness\n        },\n        topic: 'alert'\n    }]);\n} else {\n    node.send([msg, null]);\n}\nreturn null;",
        "outputs": 2,
        "noerr": 0,
        "x": 320,
        "y": 160,
        "wires": [["gauge_lux"], ["alert_handler"]]
    },
    {
        "id": "gauge_lux",
        "type": "ui_gauge",
        "z": "tab_smartdesk",
        "name": "Lux Gauge",
        "group": "ui_group_env",
        "order": 3,
        "width": "3",
        "height": "3",
        "gtype": "gage",
        "title": "Ambient Light",
        "label": "lux",
        "format": "{{value}}",
        "min": "0",
        "max": "1500",
        "colors": ["#e02020", "#ffbf00", "#00b050"],
        "seg1": "200",
        "seg2": "300",
        "x": 520,
        "y": 160,
        "wires": []
    },

