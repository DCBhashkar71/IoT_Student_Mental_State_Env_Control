    {
        "id": "parse_actuators",
        "type": "function",
        "z": "tab_smartdesk",
        "name": "Route Actuator Commands",
        "func": "var cmd = msg.payload;\n\nnode.send([\n    { payload: cmd.fan_pwm,        topic: 'fan' },\n    { payload: cmd.led_brightness,  topic: 'led_brightness' },\n    { payload: cmd.led_color_k,     topic: 'led_color' },\n    { payload: cmd.haptic ? 'ON' : 'OFF', topic: 'haptic' },\n    { payload: cmd.oled_message,    topic: 'oled' },\n    { payload: cmd.break_suggested ? 'YES — 5 min break' : 'No', topic: 'break' }\n]);\nreturn null;",
        "outputs": 6,
        "x": 340,
        "y": 920,
        "wires": [
            ["gauge_fan"],
            ["gauge_led"],
            ["display_led_color"],
            ["display_haptic"],
            ["display_oled"],
            ["display_break"]
        ]
    },
